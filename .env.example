# ============================================
# DJANGO CORE
# ============================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
DJANGO_ENV=local
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freelanceflow
DATABASE_NAME=freelanceflow
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ============================================
# REDIS (Cache/Broker/Channels)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# CELERY (Task Queue)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# OBJECT STORAGE (AWS S3)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=freelanceflow-media
AWS_S3_REGION_NAME=us-east-1
AWS_CLOUDFRONT_DOMAIN=

# ============================================
# LLM INTEGRATION (Groq)
# ============================================
GROQ_API_KEY=gsk_your_groq_api_key

# ============================================
# AI MONITORING (LangSmith)
# ============================================
LANGSMITH_API_KEY=lsv2_pt_your_langsmith_api_key
LANGSMITH_PROJECT=freelanceflow
LANGSMITH_TRACING=True

# ============================================
# SEARCH (Elasticsearch)
# ============================================
ELASTICSEARCH_URL=http://localhost:9200

# ============================================
# EMAIL (SMTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@freelanceflow.com

# ============================================
# ERROR TRACKING (Sentry)
# ============================================
SENTRY_DSN=

# ============================================
# OAUTH (Google)
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# FRONTEND & CORS
# ============================================
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# BUSINESS LOGIC
# ============================================
PLATFORM_CUT_PERCENTAGE=10
